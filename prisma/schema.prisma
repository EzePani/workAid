generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobPosting {
  id        String   @id @default(cuid())
  rawText   String
  company   String?
  role      String
  category  String
  skills      String[]
  softSkills  String[]
  level     String?
  modality  String?
  salary    String?
  location  String?
  postedAt  DateTime?
  addedAt   DateTime @default(now())
  url       String?
  notes     String?
  status    String   @default("Not Applied")

  @@map("job_postings")
}
